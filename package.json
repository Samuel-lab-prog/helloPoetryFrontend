{
	"name": "hello-poetry-frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "eslint . --cache",
		"lint:fix": "eslint . --fix --cache",
		"format": "prettier --check . --cache",
		"format:fix": "prettier --write . --cache",
		"typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
		"generate": "cd ./src/core/themes/ && npx @chakra-ui/cli typegen ./main.ts",
		"barrels": "barrelsby --config barrels.config.json",
		"check-deps": "npx dependency-cruiser src",
		"metrics:cloc": "cloc src --by-file --exclude-dir=node_modules,dist,build,coverage --json --out cloc.json",
		"metrics:depcruise": "depcruise src --exclude \"node_modules|dist|coverage\" --output-type json --output-to depcruise.json",
		"metrics:analysis": "bun architecture-analysis/src/main.ts",
		"metrics": "bun run metrics:cloc && bun run metrics:depcruise && bun run metrics:analysis",
		"depcruise": "bunx depcruise src",
		"check": "bun run lint:fix && bun run format:fix && bun run typecheck && bun run check-deps && bun run metrics && bun run build",
		"generate:api": "orval"
	},
	"dependencies": {
		"@chakra-ui/react": "^3.30.0",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@hookform/resolvers": "^5.2.2",
		"@tanstack/react-query": "^5.90.12",
		"framer-motion": "^12.23.26",
		"lucide-react": "^0.556.0",
		"next-themes": "^0.4.6",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-hook-form": "^7.65.0",
		"react-icons": "^5.6.0",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^7.9.4",
		"remark-gfm": "^4.0.1",
		"zod": "^4.1.12",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@eslint/js": "^9.33.0",
		"@types/node": "^24.12.0",
		"@types/react": "^19.1.10",
		"@types/react-dom": "^19.1.7",
		"@vitejs/plugin-react": "^5.0.0",
		"barrelsby": "^2.8.1",
		"baseline-browser-mapping": "^2.9.11",
		"cloc": "^2.6.0-cloc",
		"dependency-cruiser": "^17.3.5",
		"eslint": "^9.33.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.20",
		"eslint-plugin-simple-import-sort": "^12.1.0",
		"globals": "^16.3.0",
		"jiti": "^2.6.1",
		"kleur": "^4.1.5",
		"orval": "^8.5.3",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.39.1",
		"vite": "^7.1.2",
		"vite-tsconfig-paths": "^6.0.3"
	}
}
